{
  "name": "regex-formatter",
  "displayName": "Regex Formatter",
  "description": "Formatador e identador genérico simples baseado em regras de Expressão Regular e JSON.",
  "version": "0.0.2",
  "publisher": "filipehassen",
  "author": {
    "name": "Filipe Hassen",
    "email": "filipe.hassen@gmail.com"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/FilipeHassen/regex-formatter-vscode.git"
  },
  "homepage": "https://github.com/FilipeHassen/regex-formatter-vscode#readme",
  "bugs": {
    "url": "https://github.com/FilipeHassen/regex-formatter-vscode/issues"
  },
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Formatters"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "regex-formatter.createConfig",
        "title": "Regex Formatter: Create Configuration File"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.74.0",
    "@vscode/test-cli": "^0.0.8",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
