[
  {
    "fileExtensions": [
      "java",
      "cs"
    ],
    "indentSize": 4,
    "continuationIndentSize": 2,
    "bracesStyle": "sameLine",
    "breakBraceBlocks": true,
    "indentOnly": false,
    "forceReformat": true,
    "keepBlankLines": false,
    "lineBreakOnCharacters": [
      {
        "char": ".",
        "position": "before",
        "requireParenthesis": true
      }
    ],
    "spaces": {
      "insideParentheses": false,
      "insideBrackets": false,
      "insideBraces": true,
      "beforeParentheses": true
    },
    "commentAndStringRules": {
      "lineComment": "//",
      "blockCommentStart": "/*",
      "blockCommentEnd": "*/",
      "stringDelimiters": [
        "\"\"\"",
        "\"",
        "'"
      ]
    },
    "customRules": [
      {
        "pattern": "System\\.out\\.println",
        "replace": "System.out.println",
        "description": "Exemplo de regra regex customizada"
      }
    ]
  },
  {
    "fileExtensions": [
      "go"
    ],
    "indentSize": 4,
    "continuationIndentSize": 4,
    "bracesStyle": "sameLine",
    "breakBraceBlocks": false,
    "indentOnly": false,
    "forceReformat": false,
    "keepBlankLines": true,
    "lineBreakOnCharacters": [
      {
        "char": ".",
        "position": "after",
        "requireParenthesis": false
      }
    ],
    "spaces": {
      "insideParentheses": false,
      "insideBrackets": false,
      "insideBraces": true,
      "beforeParentheses": false
    },
    "commentAndStringRules": {
      "lineComment": "//",
      "blockCommentStart": "/*",
      "blockCommentEnd": "*/",
      "stringDelimiters": [
        "\"",
        "`"
      ]
    },
    "customRules": []
  }
]